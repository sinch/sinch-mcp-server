# Remote HTTP server (npm run start:http:server)
PORT=8000
# Single-tenant mode (default): set MCP_API_KEY and Sinch credentials below on the server.
# Clients send Authorization: Bearer <MCP_API_KEY> only.
# Multi-tenant mode: leave MCP_API_KEY unset; clients send X-Sinch-Credentials per request instead.
# Single MCP gateway API key (Authorization: Bearer …).
MCP_API_KEY=
# Optional: additional valid keys, comma-separated. Primary use case is key rotation:
# keep the previous key listed while clients migrate to a new one, then remove the old key.
# All listed keys grant the same server access (not per-client identity).
# MCP_API_KEYS=old-key-during-rotation,new-key
# Multi-tenant only: max cached OAuth clients per distinct credential (LRU eviction, default 256)
# OAUTH_TOKEN_CACHE_MAX_ENTRIES=256
# HTTP only: max concurrent MCP sessions (each holds a server + transport in memory, default 256)
# MCP_MAX_SESSIONS=256

# Conversation / Numbers tools related environment variables for authentication
PROJECT_ID=
KEY_ID=
KEY_SECRET=
# Conversation specific variables
CONVERSATION_REGION=
DEFAULT_SMS_ORIGINATOR=
GEOCODING_API_KEY=
# Verification / Voice tools related environment variables for authentication
APPLICATION_KEY=
APPLICATION_SECRET=
# Voice specific variable
CALLING_LINE_IDENTIFICATION=
# Mailgun tools related environment variables
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
MAILGUN_SENDER_ADDRESS=
