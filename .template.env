# Conversation / Numbers tools related environment variables for authentication
PROJECT_ID=
KEY_ID=
KEY_SECRET=
# Conversation specific variables
CONVERSATION_REGION=
DEFAULT_SMS_ORIGINATOR=
GEOCODING_API_KEY=
# Verification / Voice tools related environment variables for authentication
APPLICATION_KEY=
APPLICATION_SECRET=
# Voice specific variable
CALLING_LINE_IDENTIFICATION=
# Mailgun tools related environment variables
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
MAILGUN_SENDER_ADDRESS=

# OpenTelemetry (optional — enabled only when OTEL_EXPORTER_OTLP_ENDPOINT is set)
# Local stdio usage: leave unset (telemetry disabled, zero overhead).
# Hosted K8s: injected by Kyverno (kyverno.sinch.com/add-otel-endpoint: "enabled") or Helm.
# Typical cluster-local collector endpoint (OTLP gRPC):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy-daemonset.otel-collector.svc.cluster.local:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=sinch-mcp-server
OTEL_PROPAGATORS=tracecontext,baggage
LOG_LEVEL=info
